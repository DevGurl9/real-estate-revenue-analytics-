# =========================
# Python Virtual Environment
# =========================
venv/
env/
ENV/

# =========================
# Python Cache / Compiled
# =========================
__pycache__/
*.pyc
*.pyo
*.pyd

# =========================
# Jupyter Notebook
# =========================
.ipynb_checkpoints/

# =========================
# Environment Variables
# =========================
.env
.env.*

# =========================
# Logs
# =========================
*.log
*.tmp

# =========================
# OS Files
# =========================
.DS_Store
Thumbs.db

# =========================
# VS Code Settings (optional)
# =========================
.vscode/

# =========================
# Data Files (IMPORTANT)
# =========================
data/raw/*
data/processed/*
_bkup/*

# Keep folder structure but ignore files
!data/raw/.gitkeep
!data/processed/.gitkeep
!_bkup

# =========================
# Database Files
# =========================
*.sqlite
*.db

# Specifically exclude your generated DB
database/property_data.db

# =========================
# Temporary / Output Files
# =========================
*.csv
*.xlsx


# =====================================================
# Excel / Office
# =====================================================
# Temp Excel files
~$*.xlsx
~$*.xlsm

# Generated dashboards (exclude)
# dashboards/*.xlsx

# If you want to EXCLUDE built dashboard only:
# dashboards/Real_Estate_Dashboard_Built.xlsx


# =========================
# Secrets / Keys
# =========================
config/.env


# =====================================================
# Data folders
# =====================================================
# Ignore all processed data (reproducible)
data/processed/*
!data/processed/.gitkeep

# Optional: ignore raw data if large or sensitive
# data/raw/*
# !data/raw/.gitkeep


# =========================
# Word / Personal Notes
# =========================
*.docx
*.xlsx

# Optional: notes / personal files
# *_info.docx

# Allow ONLY your final deliverables
!Real Estate Analysis/

# Explicitly allow ONLY these files
!Real Estate Analysis/Rent_Pricing_Analysis_Report.docx
!Real Estate Analysis/Real_Estate_Dashboard_Template.xlsx


# =====================================================
# Specific files (your custom excludes)
# =====================================================
_continue.txt
test.py


# =====================================================
# 🧱 Keep folder structure
# =====================================================
!data/
!data/raw/
!data/processed/
!database/
!dashboards/
!notebooks/

# Keep placeholders
!data/raw/.gitkeep
!data/processed/.gitkeep
!database/.gitkeep
!dashboards/.gitkeep
!notebooks/.gitkeep
```

